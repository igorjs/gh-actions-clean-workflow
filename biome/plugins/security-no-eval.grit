// SPDX-License-Identifier: Apache-2.0
// Disallow eval() with non-literal arguments (eslint-plugin-security: detect-eval-with-expression).
// eval() with a dynamic argument executes arbitrary attacker-controlled code.
// Literal string evals ("use strict") are not flagged.
`eval($arg)` where {
    not $arg <: `"$_"`,
    not $arg <: `'$_'`,
    register_diagnostic(
        span = `eval($arg)`,
        message = "Unsafe eval() with a dynamic argument. Evaluating attacker-controlled strings is a code-injection vector."
    )
}
