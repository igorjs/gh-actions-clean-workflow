# Managed by repo-config. Direct edits are overwritten on next terraform apply.
#
# pnpm v10+ reads ONLY registry and auth settings from .npmrc; every other
# setting (strict-peer-dependencies, resolution-mode, save-exact, etc.) moved
# to pnpm-workspace.yaml. The hardened pnpm settings now live in the managed
# pnpm-workspace.yaml (see var.manage_pnpm_workspace). Keep this file
# registry/auth only.
#
# registry: lock to the official registry so no npm config in the environment
#   can redirect installs to a rogue mirror.
registry=https://registry.npmjs.org
