# Managed by repo-config. Direct edits are overwritten on next terraform apply.
#
# Hardened pnpm defaults enforced across all JS/TS repos.
#
# registry: lock to the official registry so no npm config in the
#   environment can redirect installs to a rogue mirror.
# strict-peer-dependencies: abort if peer deps are not satisfied --
#   prevents silent version mismatches.
# shamefully-hoist: keep node_modules isolated; phantom-dependency
#   resolution is a supply chain vector (imports resolve to hoisted
#   packages that are not declared dependencies).
# prefer-frozen-lockfile: abort if the lockfile needs updating; ensures
#   CI and local installs always use the same resolved graph.
# resolution-mode: always resolve to the highest satisfying version so
#   range vulnerabilities don't linger at old patch levels.
# auto-install-peers: never silently pull in unspecified peers.
# lockfile-include-tarball-url: embed registry URL in lockfile so audit
#   tools can correlate resolved packages to their source.
# verify-store-integrity: re-verify package checksums from the store on
#   every install (catches store corruption or tampering).
# ignore-scripts: suppress all lifecycle scripts (preinstall, postinstall,
#   etc.) during `pnpm install`. Prevents malicious packages from executing
#   arbitrary code at install time. Safe for pure-JS packages; repos with
#   native-addon dependencies must list them in onlyBuiltDependencies.
registry=https://registry.npmjs.org
strict-peer-dependencies=true
shamefully-hoist=false
prefer-frozen-lockfile=true
resolution-mode=highest
auto-install-peers=false
lockfile-include-tarball-url=true
verify-store-integrity=true
ignore-scripts=true
