{
  "compilerOptions": {
    "lib": ["ES2024"],
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "node_modules",
    "dist"
  ]
}
