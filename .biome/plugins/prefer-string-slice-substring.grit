// SPDX-License-Identifier: Apache-2.0
// Prefer String.prototype.slice() over .substring().
// substring() coerces negative indices to 0 and swaps start/end when
// start > end, making it error-prone. slice() handles negatives intuitively.
`$str.substring($$$)` where {
    register_diagnostic(
        span = `$str.substring($$$)`,
        message = "Use str.slice() instead of str.substring(). substring() silently coerces negatives to 0 and swaps out-of-order arguments."
    )
}
